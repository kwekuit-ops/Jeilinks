generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("USER")
  balance   Decimal  @default(0)
  storeSlug String?  @unique
  createdAt   DateTime @default(now())
  agentExpiry DateTime?
  orders      Order[]
  withdrawals Withdrawal[]

}

model Bundle {
  id                String   @id @default(cuid())
  network           String
  size              String
  userPrice         Decimal
  agentPrice        Decimal
  supplierProductId Int?
  supplierPrice     Decimal?
  isActive          Boolean  @default(true)
  orders            Order[]
}

model Order {
  id              String   @id @default(cuid())
  userId          String
  bundleId        String
  phone           String
  amount          Decimal
  status          String   @default("PENDING")
  paystackRef     String?  @unique
  paymentMethod   String   @default("PAYSTACK")
  supplierOrderId String?
  supplierStatus  String?
  agentId         String?
  commissionEarned Decimal @default(0)
  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt
  bundle          Bundle   @relation(fields: [bundleId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Withdrawal {
  id        String   @id @default(cuid())
  userId    String
  amount    Decimal
  phone     String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

